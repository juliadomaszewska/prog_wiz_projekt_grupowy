<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:prog_wiz_lab8.ViewModels"
        x:Class="prog_wiz_lab8.Views.HistoryView"
        x:DataType="vm:HistoryViewModel"
        Title="Historia Rozgrywek"
        Width="600" Height="400"
        WindowStartupLocation="CenterOwner">
    
    <Grid Background="#1E1E24" Margin="20">
        <StackPanel Spacing="10">
            <TextBlock Text="KRONIKA GIER" 
                       Foreground="Gold" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <!-- Pole z paskiem przewijania na całą wysokość historii -->
            <ScrollViewer Height="280">
                <TextBlock Text="{Binding HistoryText}" 
                           Foreground="White" FontSize="16" 
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>